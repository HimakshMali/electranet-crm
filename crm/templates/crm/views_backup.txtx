@login_required(login_url='/login')
def home(request):
    is_admin = request.user.groups.filter(name="Admin").exists()
    leads = Leads.objects.filter(is_hidden = False)
    feeds = activity_feed.objects.all()
    display_leads = Display_leads.objects.all() # select eery row from crm_Display_lead 
    products = Products.objects.all()  # ✅ A

    today = now().date()

    todays_followups = FollowUp.objects.filter(
        followup_datetime__date=today
    ).select_related('lead')





    

    if request.method == "POST":
        action = request.POST.get("action")

        # 🔥 ADD LEAD
        if action == "add_lead":
            form = LeadForm(request.POST)
            
            if form.is_valid():
                lead = form.save(commit=False)
                lead.added_by = request.user
                lead.save()

                display_lead = Display_leads(
                    added_by = request.user,
                    name = lead.name,
                    email = lead.email,
                    phone = lead.phone,
                    source = lead.source,
                    status = lead.status,
                    created_at = lead.created_at

                )

                display_lead.save()
                
               
            return redirect('home')
        
        elif action == "add_feed":
            title = request.POST.get("title")
            description = request.POST.get("description")

            if title and description:
                activity_feed.objects.create(
                    author=request.user,
                    title=title,
                    description=description
                )

            return redirect("home")

        # 🔥 DELETE LEAD
        elif action == "delete_lead":
            lead_id = request.POST.get("lead_id")
            lead = get_object_or_404(Leads, id=lead_id)
            

            if lead.added_by == request.user:
                lead.delete()

            return redirect('home')
        
        # hide lead
        elif action == "hide_lead":
            lead_id = request.POST.get("lead_id")
            lead = get_object_or_404(Leads, id=lead_id)

            if lead.added_by == request.user:
                lead.is_hidden = True
                lead.save()

            return redirect('home')

        # 🔥 EDIT LEAD
        elif action == "edit_lead":
            lead_id = request.POST.get("lead_id")
            lead = get_object_or_404(Leads, id=lead_id)
            # display_lead = get_object_or_404(Display_leads, id = display_lead_id)

            if lead.added_by == request.user:
                lead.name = request.POST.get("name")
                lead.email = request.POST.get("email")
                lead.phone = request.POST.get("phone")
                lead.source = request.POST.get("source")
                lead.status = request.POST.get("status")
                lead.save()

            return redirect('home')

        # 🔥 CONVERT LEAD → CUSTOMER
        # elif action == "convert_lead":
        #     lead_id = request.POST.get("lead_id")
        #     revenue = request.POST.get("revenue")
        #     product = request.POST.get("product")

        #     lead = get_object_or_404(Leads, id=lead_id)

        #     # prevent duplicate conversion
        #     if not Converted_leads.objects.filter(lead=lead).exists():
        #         Converted_leads.objects.create(
        #             lead=lead,
        #             closed_by=request.user,
        #             revenue_from_customer=revenue,
        #             product_bought=product
        #         )

        #     return redirect('converted_leads')  # ✅ correct redirect


        # elif action == "convert_lead":
        #     lead_id = request.POST.get("lead_id")
        #     revenue = request.POST.get("revenue")
        #     product = request.POST.get("product")

        #     lead = get_object_or_404(Leads, id=lead_id)

        #     if not Converted_leads.objects.filter(lead=lead).exists():
        #         converted = Converted_leads.objects.create(
        #             lead=lead,
        #             closed_by=request.user,
        #             revenue_from_customer=revenue,
        #             product_bought=product
        #         )

        #         # 🔥 Create Client automatically
        #         Client.objects.create(
        #             converted_lead=converted,
        #             closed_by=request.user,
        #             billed_amount=revenue  # you can change logic later
        #         )

        #     return redirect('converted-leads')



        elif action == "convert_lead":
            lead_id = request.POST.get("lead_id")
            lead = get_object_or_404(Leads, id=lead_id)

            product_ids = request.POST.getlist("product_ids[]")
            quantities = request.POST.getlist("quantities[]")

            total_revenue = 0
            product_summary = []

            converted, created = Converted_leads.objects.get_or_create(
                lead=lead,
                defaults={
                    "closed_by": request.user,
                    "revenue_from_customer": 0,
                    "product_bought": "",
                }
            )

            if not created:
                converted.items.all().delete()

            for product_id, qty in zip(product_ids, quantities):
                if not product_id or not qty:
                    continue

                product = get_object_or_404(Products, id=product_id)
                quantity = int(qty)

                line_total = product.unit_price_incl_gst * quantity
                total_revenue += line_total

                ConvertedLeadItem.objects.create(
                    converted_lead=converted,
                    product=product,
                    quantity=quantity,
                    unit_price_incl_gst=product.unit_price_incl_gst,
                    gst_rate=product.gst_rate,
                    hsn_code=product.hsn_code,
                    line_total=line_total
                )

                product_summary.append(f"{product.name} x {quantity}")

            converted.revenue_from_customer = total_revenue
            converted.product_bought = ", ".join(product_summary)
            converted.closed_by = request.user
            converted.save()

            Client.objects.get_or_create(
                converted_lead=converted,
                defaults={
                    "closed_by": request.user,
                    "billed_amount": total_revenue,
                }
            )

            lead.status = "Finalised"
            lead.save()

            return redirect("converted_leads")

    lead_form = LeadForm()

    return render(request, 'crm/home.html', {
        'is_admin': is_admin,
        'leads': leads,
        'display_leads' : display_leads, # display_leads = DIsplay_leads.obleects.all waleee
        'lead_form': lead_form,
        'products': products, 
        'username': request.user.username,
        "todays_followups": todays_followups,
        'feeds': feeds,
    })

@login_required(login_url='/login')
def converted_leads(request):
    if request.method == "POST":
        action = request.POST.get("action")

        if action == "add_payment":
            client_id = request.POST.get("client_id")
            amount = request.POST.get("amount")
            note = request.POST.get("note")

            client = get_object_or_404(Client, id=client_id)

            Payment.objects.create(
                client=client,
                amount=amount,
                note=note
            )

            messages.success(request, "Payment added successfully.")
            return redirect("converted_leads")

        elif action == "delete_converted_lead":
            converted_lead_id = request.POST.get("converted_lead_id")

            converted_lead = get_object_or_404(Converted_leads, id=converted_lead_id)
            converted_lead.delete()

            messages.success(request, "Converted lead deleted successfully.")
            return redirect("converted_leads")

    leads = Converted_leads.objects.select_related(
        "lead",
        "closed_by"
    ).order_by("-closed_at")

    return render(request, "crm/converted_leads.html", {
        "leads": leads
    })
@login_required(login_url='/login')
def ledger_dashboard(request):
    clients = Client.objects.select_related(
        "converted_lead",
        "converted_lead__lead",
        "closed_by"
    ).prefetch_related("payments").all()

    total_billed = 0
    total_paid = 0
    total_remaining = 0

    for client in clients:
        client.paid_amount = client.total_paid()
        client.remaining = client.remaining_amount()

        total_billed += client.billed_amount
        total_paid += client.paid_amount
        total_remaining += client.remaining

    return render(request, "crm/ledger_dashboard.html", {
        "clients": clients,
        "total_billed": total_billed,
        "total_paid": total_paid,
        "total_remaining": total_remaining,
    })

