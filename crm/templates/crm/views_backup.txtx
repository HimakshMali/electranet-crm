# 🔹 Employee List
@login_required(login_url='/login')
@login_required(login_url='/login')
def employees_list(request):

    if not request.user.groups.filter(name="Admin").exists():
        return HttpResponseForbidden("Not allowed")

    employees = Employee.objects.select_related('user').all()

    # 🔥 Attach deals + total revenue to each employee
    for emp in employees:
        deals = Converted_leads.objects.filter(closed_by=emp.user)

        emp.deals = deals
        emp.total_revenue = deals.aggregate(
            total=Sum('revenue_from_customer')
        )['total'] or 0

    return render(request, 'crm/employees_list.html', {
        'employees': employees
    })

# 🔹 Edit Employee
@login_required(login_url='/login')
def edit_employee(request, id):

    if not request.user.groups.filter(name="Admin").exists():
        return HttpResponseForbidden("Not allowed")

    employee = get_object_or_404(Employee, id=id)
    user = employee.user

    if request.method == "POST":
        form = EmployeeUpdateForm(request.POST, instance=employee, user=user)

        if form.is_valid():
            form.save()

            # update user fields
            user.first_name = form.cleaned_data['first_name']
            user.last_name = form.cleaned_data['last_name']
            user.email = form.cleaned_data['email']
            user.save()

            return redirect('/employees')

    else:
        form = EmployeeUpdateForm(instance=employee, user=user)

    return render(request, 'crm/edit_employee.html', {
        'form': form
    })


