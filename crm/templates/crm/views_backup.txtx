@login_required(login_url='/login')
def customer_ledger_view(request, customer_id):
    """
    Displays the detailed financial statement for a specific customer.
    """
    # 1. Fetch data from service layer
    ledger_data = get_customer_ledger(customer_id)
    
    # ledger_data contains: customer, invoices, total_billed, total_paid, total_due
    return render(request, 'crm/ledger.html', ledger_data)

@login_required(login_url='/login')
def ledger_list_view(request):
    """
    Overview page showing all customers and their current outstanding balances.
    """
    customers = Customer.objects.all()
    
    # Add temporary calculation for the list view
    for customer in customers:
        invoices = customer.invoices.all()
        billed = sum(inv.total_amount for inv in invoices)
        paid = sum(inv.total_paid for inv in invoices)
        customer.total_due = billed - paid

    return render(request, 'crm/ledger.html', {'customers': customers})



def elementshtml(request):
     return render(request, 'crm/elements.html')

@login_required(login_url='/login')
def add_activity_feed_post(request):
    if request.method == 'POST':
        form = acticitefeedform(request.POST)

        if form.is_valid():
            feed = form.save(commit=False)
            feed.author = request.user
            feed.save()
            return redirect('home')
    else:
        form = acticitefeedform()

    return render(request, 'crm/create_post.html', {'form': form})




@login_required(login_url='/login')
def employee_salary(request, employee_id):
    employee = get_object_or_404(Employee, id = employee_id)

    if request.method == 'POST':
        month = request.POST.get("month")
        year = request.POST.get("year")
        base_salary = request.POST.get("base_salary")
        total_bonus = request.POST.get("total_bonus") or 0
        total_deductions = request.POST.get("total_deductions") or 0
        status = request.POST.get("status")
        notes = request.POST.get("notes")

        SalaryRecord.objects.create(
            employee = employee,
            month=month,
            year=int(year),
            base_salary=Decimal(base_salary),
            total_bonus=Decimal(total_bonus),
            total_deductions=Decimal(total_deductions),
            status=status,
            notes=notes,

        )

        return redirect('employee_salary', employee_id = employee.id)
    

    salary_records = SalaryRecord.objects.filter(employee=employee).order_by('-year', '-created_at')

    return render(request, 'crm/salary.html', {
        'employee': employee,
        'salary_records': salary_records,
    })



@login_required(login_url='/login')
def customer_invoice(request, converted_lead_id):
    converted_lead = get_object_or_404(Converted_leads, id=converted_lead_id)

    # 🔥 Get all products for this converted lead
    invoice_items = converted_lead.items.select_related("product")

    if request.method == "POST":
        # 🔥 Collect all form data
        data = {
            "customer_name": request.POST.get("customer_name"),
            "customer_email": request.POST.get("customer_email"),
            "customer_phone": request.POST.get("customer_phone"),
            "customer_address": request.POST.get("customer_address"),
            "customer_gstin": request.POST.get("customer_gstin"),
            "delivery_address": request.POST.get("delivery_address"),
            "invoice_number": request.POST.get("invoice_number"),
            "invoice_date": request.POST.get("invoice_date"),
            "vehicle": request.POST.get("vehicle"),
            "discount": request.POST.get("discount"),
            "final_amount": request.POST.get("final_amount"),
        }

        # 🔥 Collect product rows (already auto-filled)
        product_names = request.POST.getlist("product_name[]")
        hsn_codes = request.POST.getlist("hsn_code[]")
        gst_rates = request.POST.getlist("gst_rate[]")
        prices = request.POST.getlist("unit_price_incl_gst[]")
        quantities = request.POST.getlist("quantity[]")

        products = []

        for i in range(len(product_names)):
            products.append({
                "name": product_names[i],
                "hsn": hsn_codes[i],
                "gst": gst_rates[i],
                "price": prices[i],
                "qty": quantities[i],
                "total": float(prices[i]) * int(quantities[i])
            })

        # 🔥 CALL YOUR PDF FUNCTION HERE
        # (you said you already have it)
        from crm.functions.invoicegenerator import generate_invoice_pdf

        return generate_invoice_pdf(data, products)

    return render(request, "crm/customer-invoice.html", {
        "converted_lead": converted_lead,
        "invoice_items": invoice_items,
    })