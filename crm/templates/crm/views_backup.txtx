def clients(request):
    clients = Client.objects.all()
    return render(request, "crm/clients.html", {"clients": clients})


def client_detail(request, client_id):
    client = get_object_or_404(Client, id=client_id)

    if request.method == "POST":
        amount = request.POST.get("amount")
        date = request.POST.get("date")

        Payment.objects.create(
            client=client,
            amount=amount,
            paid_on=date
        )

        return redirect('client_detail', client_id=client.id)

    payments = client.payments.all().order_by('-paid_on')

    return render(request, "client_detail.html", {
        "client": client,
        "payments": payments
    })

def generate_code():
    return ''.join(random.choices(string.ascii_uppercase + string.digits, k=6))


def sign_up(request):
    if request.method == "POST":
        form = RegisterForm(request.POST)

        if form.is_valid():
            user = form.save()
            login(request, user)

            role = form.cleaned_data.get('role')
            project_name = form.cleaned_data.get('project_name')
            invitation_code = form.cleaned_data.get('invitation_code')

            # 🔹 Assign group (your old logic)
            if role == "admin":
                group = Group.objects.get(name="Admin")
            else:
                group = Group.objects.get(name="Employee")

            user.groups.add(group)

            # 🔥 PROJECT LOGIC
            if role == "admin":
                # Admin creates project
                code = generate_code()

                project = Project.objects.create(
                    name=project_name,
                    invitation_code=code,
                    created_by=user
                )

                Membership.objects.create(
                    user=user,
                    project=project,
                    role='admin'
                )

            else:
                # Employee joins using invitation code
                try:
                    project = Project.objects.get(invitation_code=invitation_code)

                    Membership.objects.create(
                        user=user,
                        project=project,
                        role='employee'
                    )

                except Project.DoesNotExist:
                    return render(request, 'registration/sign-up.html', {
                        'form': form,
                        'error': 'Invalid invitation code'
                    })

            return redirect('/home')

    else:
        form = RegisterForm()

    return render(request, 'registration/sign-up.html', {'form': form})

@login_required(login_url='/login')
def add_employee(request):

    if not request.user.groups.filter(name="Admin").exists():
        return HttpResponseForbidden("Not allowed")

    if request.method == "POST":
        form = EmployeeCreateForm(request.POST)

        if form.is_valid():
            user = form.save()

            # Assign Employee group
            group = Group.objects.get(name="Employee")
            user.groups.add(group)

            # 🔥 Create Employee profile
            Employee.objects.create(
                user=user,
                salary=form.cleaned_data['salary'],
                joined_since=form.cleaned_data['joined_since'],
                role=form.cleaned_data['role'],
                address=form.cleaned_data['address'],
                contact_number=form.cleaned_data['contact_number'],
            )

            return redirect('/home')

    else:
        form = EmployeeCreateForm()

    return render(request, 'crm/add_employee.html', {'form': form})

@login_required
def create_lead(request):
    if request.method == "POST":
        form = LeadForm(request.POST)
        if form.is_valid():
            lead = form.save(commit=False) # it creates a new lead object from the form data but does not save it to the database yet
            lead.added_by = request.user # it assigns the currently logged-in user as the one who added the lead
            lead.save() # it saves the lead to the database
            return redirect('/home')

    else:
        form = LeadForm()

    return render(request,'crm/create_lead.html',{'form':form})



