@login_required(login_url='/login')
def add_followup(request):
    if request.method == "POST":
        lead_id = request.POST.get("lead_id")
        datetime_value = request.POST.get("followup_datetime")
        note = request.POST.get("note")

        lead = get_object_or_404(Leads, id=lead_id)

        followup = FollowUp.objects.create(
            lead = lead,
            followup_datetime = datetime_value,
            note=note,
            created_by=request.user
        )

        LeadActivity.objects.create(
            lead=lead,
            activity_type='followup',
            note=note,
            activity_time=datetime_value,
            created_by=request.user
        )


        # ✅ Restriction: only Contacted leads
        if lead.status != "Contacted":
            messages.error(request, "Follow-up allowed only for Contacted leads.")
            return redirect("home")

        FollowUp.objects.create(
            lead=lead,
            followup_datetime=datetime_value,
            note=note,
            created_by=request.user
        )

        messages.success(request, "Follow-up added successfully!")
        return redirect("home")
def edit_followup(request):
    if request.method == "POST":
        followup_id = request.POST.get("followup_id")
        datetime_value = request.POST.get("followup_datetime")
        note = request.POST.get("note")

        followup = get_object_or_404(FollowUp, id=followup_id)

        # Optional: restrict to creator
        if request.user != followup.created_by:
            messages.error(request, "Not allowed")
            return redirect("home")

        followup.followup_datetime = datetime_value
        followup.note = note
        followup.save()

        messages.success(request, "Follow-up updated")
        return redirect("home")
    

def delete_followup(request):
    if request.method == "POST":
        followup_id = request.POST.get("followup_id")

        followup = get_object_or_404(FollowUp, id=followup_id)

        if request.user != followup.created_by:
            messages.error(request, "Not allowed")
            return redirect("home")

        followup.delete()
        messages.success(request, "Follow-up deleted")
        return redirect("home")
    


def lead_detail(request, lead_id):
    lead = get_object_or_404(Leads, id = lead_id)

    activities = lead.activities.all().order_by('activity_time')

    return render(request, 'crm/lead_detail.html', {

        'lead' : lead, 
        'activities' : activities
    })


@login_required(login_url='/login')
def products_page(request):

    if request.method == "POST":
        action = request.POST.get("action")

        if action == "add":
            Products.objects.create(
                name=request.POST.get("name"),
                hsn_code=request.POST.get("hsn_code"),
                unit_price_incl_gst=Decimal(request.POST.get("unit_price_incl_gst") or 0),
                gst_rate=Decimal(request.POST.get("gst_rate") or 18),
                inventory=int(request.POST.get("inventory") or 0),
                supplier=request.POST.get("supplier")
            )
            return redirect('products')

        elif action == "delete":
            product = get_object_or_404(Products, id=request.POST.get("id"))
            product.delete()
            return redirect('products')

        elif action == "edit":
            product = get_object_or_404(Products, id=request.POST.get("id"))

            product.name = request.POST.get("name")
            product.hsn_code = request.POST.get("hsn_code")
            product.unit_price_incl_gst = Decimal(request.POST.get("unit_price_incl_gst") or 0)
            product.gst_rate = Decimal(request.POST.get("gst_rate") or 18)
            product.inventory = int(request.POST.get("inventory") or 0)
            product.supplier = request.POST.get("supplier")
            product.save()

            return redirect('products')

    products = Products.objects.all().order_by('-id')

    return render(request, 'crm/products.html', {
        'products': products
    })  





# incoice

@login_required(login_url='/login')
def create_invoice(request):
    if request.method == "POST":
        form = InvoiceForm(request.POST)
        
        if form.is_valid():
            # 1. Prepare data for the Database Service
            # We use the cleaned_data from your form
            invoice_metadata = {
                "number": form.cleaned_data['invoice_number'],
                "date": form.cleaned_data['invoice_date'],
                "discount": form.cleaned_data['discount'] or 0,
                "vehicle": form.cleaned_data['vehicle'],
            }

            # 2. Get the Dynamic Product Data (Not in the form)
            product_names = request.POST.getlist('product_name[]')
            hsn_codes = request.POST.getlist('hsn_code[]')
            unit_prices = request.POST.getlist('unit_price_incl_gst[]')
            gst_rates = request.POST.getlist('gst_rate[]')
            quantities = request.POST.getlist('quantity[]')
            product_ids = request.POST.getlist('product_id[]')

            items_data = []
            for i in range(len(product_names)):
                if not unit_prices[i] or not quantities[i]:
                    continue
                items_data.append({
                    'product_id': product_ids[i] if (i < len(product_ids) and product_ids[i]) else None,
                    'name': product_names[i],
                    'hsn_code': hsn_codes[i],
                    'unit_price': unit_prices[i],
                    'gst_rate': gst_rates[i],
                    'quantity': quantities[i],
                })

            # 3. SAVE TO DATABASE
            # Note: Since your form has manual name/address, we either find or create a Customer
            customer_obj, created = Customer.objects.get_or_create(
                phone=form.cleaned_data['customer_phone'],
                defaults={
                    'name': form.cleaned_data['customer_name'],
                    'address': form.cleaned_data['customer_address'],
                    'email': form.cleaned_data['customer_email'],
                    'gstin': form.cleaned_data['customer_gstin'],
                }
            )

            # Call your service to handle the complex DB logic
            invoice = create_full_invoice(request.user, customer_obj.id, invoice_metadata, items_data)

            # 4. GENERATE PDF (using the saved invoice object)
            pdf_data = {
                "customer": {
                    "name": invoice.customer.name,
                    "address": invoice.customer.address,
                    "phone": invoice.customer.phone,
                    "email": invoice.customer.email,
                    "gstin": invoice.customer.gstin,
                },
                "invoice": {
                    "number": invoice.invoice_number,
                    "date": str(invoice.invoice_date),
                    "discount": float(invoice.discount),
                    "vehicle": invoice.vehicle,
                },
                "products": [
                    {
                        "name": item.product_name,
                        "hsn": item.hsn_code,
                        "price": float(item.unit_price),
                        "gst": float(item.gst_rate),
                        "qty": float(item.quantity)
                    } for item in invoice.items.all()
                ]
            }

            pdf_buffer = generate_invoice_pdf(pdf_data)
            response = HttpResponse(pdf_buffer, content_type='application/pdf')
            response['Content-Disposition'] = f'attachment; filename="invoice_{invoice.invoice_number}.pdf"'
            return response
    else:
        form = InvoiceForm()

    # GET Request
    return render(request, "crm/Invoice.html", {
        "form": form,
        "products": Products.objects.all(),
        "customers": Customer.objects.all()
    })
